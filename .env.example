####################
## Environment    ##
####################
LOGIN_EMAIL="" # Your email from your Penpot account
SECOND_EMAIL="" # A secondary email for tests that require it, needs same password than LOGIN_EMAIL
LOGIN_PWD="" # Your password from your Penpot account
BASE_URL="" # Penpot url - e.g. http://localhost:9001/ if deployed locally

# TEST_RUN_ID should be injected by CI (e.g. GitHub run id). If not set, globalSetup will generate one.
# TEST_RUN_ID=

# — Optional: set to true to delete all teams created in bulk (default is run-scoped) —
# FULL_CLEANUP=false

######################
## Docker (optional) ##
######################

# — Override the platform for `npm run test:docker[:ui]` (e.g. on Apple Silicon) —
# Default (linux/amd64) works as-is on Windows and Linux x86_64 (native, no emulation) — leave it commented out.
# On an ARM64 host (e.g. Apple Silicon, Windows/Linux ARM), you can uncomment the line below to run
# natively instead of emulating amd64, as long as the image tag below has an arm64 build:
# DOCKER_PLATFORM=linux/arm64

# — Playwright Docker image tag, should match the resolved @playwright/test version (see package-lock.json) —
# PLAYWRIGHT_DOCKER_TAG=v1.61.1-noble

######################
## Integrations     ##
######################

## Information needed for Gmail integration
GMAIL_NAME="" # Gmail account name for email verification
GMAIL_DOMAIN="" # Gmail domain for email verification
REFRESH_TOKEN="" # Gmail Refresh Token for email access
CLIENT_ID="" # Gmail Client ID for email access
CLIENT_SECRET="" # Gmail Client Secret for email access
STRIPE_SK="" # Stripe Secret Key for payment processing


######################
## Qase Reporter    ##
######################

QASE_API_TOKEN=your_qase_api_token_here
QASE_MODE=testops
QASE_PROJECT_CODE=YOUR_PROJECT_CODE
